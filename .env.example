# ──────────────────────────────────────────────
# Review Copilot — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local for local development.
# In production, set these in your Vercel dashboard under
# Project Settings → Environment Variables.
# NEVER commit .env.local to git.

# Required: Your Anthropic API key
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required in production: Your deployed URL (no trailing slash)
# Used for CORS — only requests from this origin will be accepted
ALLOWED_ORIGIN=https://your-project.vercel.app

# Optional: Node environment (set automatically by Vercel)
# NODE_ENV=production
